# ── LLM 配置 ──────────────────────────────────────────────
# 规范类型：openai（兼容 OpenAI API 的所有服务）或 anthropic
LLM_PROVIDER=openai

# API Key
LLM_API_KEY=你的key

# API 地址（OpenAI 规范时填写；使用官方 OpenAI 可留空）
# DeepSeek:  https://api.deepseek.com
# 通义:       https://dashscope.aliyuncs.com/compatible-mode/v1
# 硅基流动:   https://api.siliconflow.cn/v1
# 火山引擎:   https://ark.cn-beijing.volces.com/api/v3
# Kimi:      https://api.moonshot.cn/v1
# OpenAI:    留空即可（默认 https://api.openai.com/v1）
LLM_BASE_URL=https://api.openai.com/v1

# 模型名称
# OpenAI:    gpt-5.4 / gpt-5.4-mini（推荐）/ gpt-5.4-nano
# DeepSeek:  deepseek-chat (V3.2) / deepseek-reasoner (V3.2)
# 通义:       qwen-max-latest / qwen3.5-max-preview / qwen-plus
# 硅基流动:   Qwen/Qwen-3-8B（免费）/ Qwen/Qwen3.5-397B-A17B
# 火山引擎:   doubao-seed-2-0-pro / doubao-seed-2-0-lite / doubao-seed-2-0-code
# Kimi:      kimi-k2.5
# Anthropic: claude-sonnet-4-6 / claude-opus-4-6 / claude-haiku-4-5
LLM_MODEL=gpt-5.4-mini

# ── Embedding 配置（RAG 素材库）────────────────────────────
# 向量化模型
# OpenAI:    text-embedding-3-small（推荐）/ text-embedding-3-large
# 通义:       text-embedding-v4（推荐）/ text-embedding-v3
# 硅基流动:   BAAI/bge-m3
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BASE_URL=  # 留空则跟 LLM_BASE_URL 一致
# EMBEDDING_API_KEY=   # 留空则复用 LLM_API_KEY

# ── 搜索 ─────────────────────────────────────────────────
TAVILY_API_KEY=tvly-你的key

# ── 配图 ─────────────────────────────────────────────────
# Provider: prompt / screenshot / mixed / unsplash / openai / gemini / openrouter / replicate / dashscope
#   prompt     — 仅生成提示词占位（免费，手动去 Gemini 等平台生图后上传）
#   screenshot — 网页截图（Playwright 截取官方页面，需 playwright install chromium）
#   mixed      — 混合模式（截图 + AI 生图，Writer 根据内容自动选择）
#   unsplash   — 摄影图搜索（免费）
#   openai     — OpenAI 兼容 /images/generations（含 gpt-image、Seedream/豆包 等）
#   gemini     — Google Gemini 原生生图
#   openrouter — OpenRouter 聚合（可调 Gemini、FLUX 等）
#   replicate  — Replicate 托管模型（按量付费）
#   dashscope  — 通义万相
IMAGE_PROVIDER=prompt

# Unsplash 搜图密钥（IMAGE_PROVIDER=unsplash 时需要）
# UNSPLASH_ACCESS_KEY=你的key

# AI 生图统一配置（非 unsplash/prompt 时使用）
# IMAGE_API_KEY=             # 留空则复用 LLM_API_KEY
# IMAGE_BASE_URL=            # 留空使用 Provider 默认地址
# IMAGE_MODEL=               # 留空使用 Provider 默认模型

# 各 Provider 的 Base URL 和推荐模型：
#   openai:     （留空）          gpt-image-1 / dall-e-3
#   openai+豆包: https://ark.cn-beijing.volces.com/api/v3   doubao-seedream-5-0-260128
#   gemini:     （留空）          gemini-2.0-flash-preview-image-generation
#   openrouter: （留空）          google/gemini-2.0-flash-preview-image-generation
#   replicate:  （留空）          google/nano-banana-pro
#   dashscope:  （留空）          qwen-image-2.0-pro

# 图片风格预设: warm/fresh/minimal/notion/retro/bold/cute/chalkboard
# 不填则按平台自动选择（公众号=warm, 小红书=fresh, 知乎=minimal）
# IMAGE_STYLE=

# 并发生图: true/false（默认 false，多数生图模型不支持并发）
# IMAGE_CONCURRENT=false

# ── 微信公众号发布（可选）──────────────────────────────────
# 获取方式：mp.weixin.qq.com → 开发 → 基本配置
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# WECHAT_DEFAULT_AUTHOR=     # 默认作者名

# ── LangSmith 调试（可选）────────────────────────────────
# 注册地址：smith.langchain.com（免费）
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=你的key
LANGCHAIN_PROJECT=content-agent
